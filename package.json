{
  "name": "workpack-manager",
  "displayName": "Workpack Manager",
  "description": "VS Code extension for discovering and managing workpacks.",
  "version": "0.0.2",
  "license": "MIT",
  "publisher": "daurmax",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#0b1220",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daurmax/WorkpackManager.git"
  },
  "bugs": {
    "url": "https://github.com/daurmax/WorkpackManager/issues"
  },
  "homepage": "https://github.com/daurmax/WorkpackManager#readme",
  "activationEvents": [
    "onStartupFinished",
    "onView:workpackManager",
    "onView:workpackManager.activeAgents",
    "onView:workpackManager.gitDiff",
    "onCommand:workpackManager.showDiffPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workpack-manager",
          "title": "Workpack Manager",
          "icon": "$(tasklist)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "workpackManager",
          "name": "Workpacks",
          "icon": "$(tasklist)",
          "contextualTitle": "Workpack Manager"
        },
        {
          "id": "workpackManager.activeAgents",
          "name": "Active Agents",
          "icon": "$(pulse)",
          "contextualTitle": "Workpack Manager"
        },
        {
          "id": "workpackManager.gitDiff",
          "name": "Git Diff",
          "icon": "$(git-compare)",
          "contextualTitle": "Workpack Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "workpackManager.createWorkpack",
        "title": "Create New",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.scaffoldFromTemplate",
        "title": "Scaffold from Template",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.lintWorkpack",
        "title": "Lint",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.openRequest",
        "title": "Open Request",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.openPlan",
        "title": "Open Plan",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.openStatus",
        "title": "Open Status",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.openPixelRoom",
        "title": "Open Pixel Room",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.showDiffPanel",
        "title": "Show Git Diff Panel",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.refreshGitDiff",
        "title": "Refresh Git Diff",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.viewDetails",
        "title": "View Details",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.assignAgent",
        "title": "Assign Agent",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.executePrompt",
        "title": "Execute Prompt",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.executeAll",
        "title": "Execute All Ready Prompts",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.stopPromptExecution",
        "title": "Stop Prompt",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.retryPrompt",
        "title": "Retry Prompt",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.provideAgentInput",
        "title": "Provide Agent Input",
        "category": "Workpack"
      },
      {
        "command": "workpackManager.refreshTree",
        "title": "Refresh",
        "category": "Workpack",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "workpackManager.refreshTree",
          "when": "view == workpackManager",
          "group": "navigation"
        },
        {
          "command": "workpackManager.refreshTree",
          "when": "view == workpackManager.activeAgents",
          "group": "navigation"
        },
        {
          "command": "workpackManager.refreshGitDiff",
          "when": "view == workpackManager.gitDiff",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "workpackManager.openRequest",
          "when": "viewItem == workpack",
          "group": "1_open@1"
        },
        {
          "command": "workpackManager.openPlan",
          "when": "viewItem == workpack",
          "group": "1_open@2"
        },
        {
          "command": "workpackManager.openStatus",
          "when": "viewItem == workpack",
          "group": "1_open@3"
        },
        {
          "command": "workpackManager.viewDetails",
          "when": "viewItem == workpack",
          "group": "1_open@4"
        },
        {
          "command": "workpackManager.openPixelRoom",
          "when": "viewItem == workpack",
          "group": "1_open@5"
        },
        {
          "command": "workpackManager.lintWorkpack",
          "when": "viewItem == workpack",
          "group": "2_actions@1"
        },
        {
          "command": "workpackManager.executeAll",
          "when": "viewItem == workpack",
          "group": "2_actions@2"
        },
        {
          "command": "workpackManager.assignAgent",
          "when": "viewItem =~ /^prompt\\./",
          "group": "1_agent@1"
        },
        {
          "command": "workpackManager.executePrompt",
          "when": "viewItem == prompt.pending",
          "group": "1_agent@2"
        },
        {
          "command": "workpackManager.stopPromptExecution",
          "when": "viewItem == prompt.queued || viewItem == prompt.inProgress || viewItem == prompt.humanInputRequired || viewItem == activeAgent.queued || viewItem == activeAgent.inProgress || viewItem == activeAgent.humanInputRequired",
          "group": "1_agent@3"
        },
        {
          "command": "workpackManager.retryPrompt",
          "when": "viewItem == prompt.blocked || viewItem == prompt.failed || viewItem == prompt.cancelled",
          "group": "1_agent@4"
        },
        {
          "command": "workpackManager.provideAgentInput",
          "when": "viewItem == prompt.humanInputRequired || viewItem == activeAgent.humanInputRequired",
          "group": "1_agent@5"
        }
      ]
    },
    "configuration": {
      "title": "Workpack Manager",
      "properties": {
        "workpackManager.autoDiscovery": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan workspace folders for workpacks/instances."
        },
        "workpackManager.codex.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI API base URL"
        },
        "workpackManager.codex.model": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Model identifier"
        },
        "workpackManager.codex.maxResponseTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum response tokens"
        },
        "workpackManager.copilot.maxPromptTokens": {
          "type": "number",
          "default": 8192,
          "description": "Maximum prompt tokens sent to GitHub Copilot requests."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "vscode:prepublish": "npm run build",
    "package:vsix": "vsce package",
    "install:local-vsix": "node ./scripts/install-local-vsix.mjs",
    "package:vsix:list": "vsce ls",
    "watch": "tsc -watch -p .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:extension": "npm run build && mocha \"out/test/**/*.test.js\""
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.96.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.36.0",
    "mocha": "^11.7.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  }
}
