{
  "name": "@workpack/protocol",
  "version": "0.1.0",
  "description": "Workpack protocol schemas, templates, and agent documentation",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daurmax/WorkpackManager.git",
    "directory": "packages/protocol"
  },
